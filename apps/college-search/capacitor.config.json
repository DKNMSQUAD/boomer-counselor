{
  "appId": "com.boomercounselor.app",
  "appName": "Boomer Counselor",
  "webDir": "../../dist-native",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "contentInset": "automatic"
  },
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#f5f0e8",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
